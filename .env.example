# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Application Configuration
VITE_APP_NAME="Irfan Shekh Portfolio"
VITE_APP_URL="https://your-domain.com"

# Contact Information
VITE_CONTACT_EMAIL="your-email@example.com"
VITE_CONTACT_PHONE="+91 XXXXXXXXXX"

# Social Media Links
VITE_LINKEDIN_URL="https://linkedin.com/in/your-profile"
VITE_GITHUB_URL="https://github.com/your-username"
VITE_FACEBOOK_URL="https://facebook.com/your-profile"
VITE_INSTAGRAM_URL="https://instagram.com/your-profile"

# Analytics (Optional)
# VITE_GA_TRACKING_ID="G-XXXXXXXXXX"

# EmailJS Configuration (Optional - for contact form)
# VITE_EMAILJS_SERVICE_ID="your_service_id"
# VITE_EMAILJS_TEMPLATE_ID="your_template_id"
# VITE_EMAILJS_PUBLIC_KEY="your_public_key"

# Error Tracking (Optional)
# VITE_SENTRY_DSN="https://your-sentry-dsn"

# Gemini API Key
GEMINI_API_KEY="your_gemini_api_key_here"

# Feature Flags
VITE_ENABLE_3D_ANIMATIONS="true"
VITE_ENABLE_ANALYTICS="false"
